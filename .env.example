# Database
DATABASE_URL="postgresql://community:community_dev_pw@localhost:5432/community"

# Auth.js (NextAuth v5) — 운영 시 반드시 변경하세요. 생성: npx auth secret
AUTH_SECRET="change_me"
AUTH_TRUST_HOST=true
# 동료가 접속하는 호스트 PC의 사내망 주소 (예: http://192.168.0.10:3000)
AUTH_URL="http://localhost:3000"

# 파일 업로드 저장 경로 (내부망 로컬 디스크)
UPLOAD_DIR="./uploads"
